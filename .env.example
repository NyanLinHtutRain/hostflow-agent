# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps / Places API
# Enable at: https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Telegram Bot Alert System
# Step 1: Message @BotFather on Telegram -> /newbot -> copy the token
# Step 2: Message @HostFlowAi_bot on Telegram, then run getUpdates to get your chat ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

